# ========== 인증 ==========
# 휴대폰 SMS OTP — Supabase Phone + 유료 통신 연동 시에만 true (기본 비활성)
# NEXT_PUBLIC_PHONE_AUTH_ENABLED=false

# 시니어는 이메일이 없을 수 있어 MVP에서는 **이메일 인증 없이 시작(익명 세션)**합니다.
# 동작 조건: Supabase Dashboard → Authentication → Providers → **Anonymous** 활성화
# (추후 휴대폰 인증/연동으로 계정 복구·기기 변경을 지원할 예정)

# 본인인증 게이트: false(기본·미설정)이면 고용주 공고 등록에 profiles.identity_verified_at 필요
# 인증 성공당 과금을 줄이려면 가입은 이메일만, PASS/SMS는 필요한 화면에서만.
# 로컬·1인 개발 시 게이트 끄기: true
# NEXT_PUBLIC_SKIP_IDENTITY_GATE=true

# ========== Supabase ==========
# Supabase Dashboard → Project Settings → API
# 설정 시 홈 지도는 job_postings(active+approved+좌표)를 우선 조회합니다. 없으면 MOCK/Faker.
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key

# ========== 카카오맵 (지도가 안 나오면 아래 순서 확인) ==========
# 1) https://developers.kakao.com/ 로그인 → 내 애플리케이션 → 앱 선택(또는 생성)
# 2) [앱 키] 탭에서 **JavaScript 키** 복사 (REST API 키 / 네이티브 앱 키 아님)
# 3) [플랫폼] → Web 플랫폼 등록 → 사이트 도메인에 **브라우저 주소와 동일하게** 입력
#    - 예: 로컬에서 http://localhost:3000 로 열면 → http://localhost:3000
#    - http://127.0.0.1:3000 으로 열면 → 127.0.0.1용도 따로 추가
#    (localhost 와 127.0.0.1 은 서로 다른 도메인으로 취급됨)
# 4) 앱 상태가 ‘서비스 ON’ 등 사용 가능한지 확인
# 5) 이 파일을 .env.local 로 복사한 뒤 값 넣고 → npm run dev **완전히 재시작**
NEXT_PUBLIC_KAKAO_MAP_APP_KEY=your_javascript_key

# 공고 근무지 주소 → 좌표 (서버 전용). [앱 키] 탭의 REST API 키 (JavaScript 키와 다름)
# 없으면 등록 시 PRD 프리셋 구역 좌표로 저장됩니다.
# KAKAO_REST_API_KEY=

# ========== Expo(앱)에서 Supabase 쓸 때 (이름만 다름, 값은 동일) ==========
# EXPO_PUBLIC_SUPABASE_URL=
# EXPO_PUBLIC_SUPABASE_ANON_KEY=

# ========== 서버 전용 (클라이언트에 넣지 말 것) ==========
# Supabase Dashboard → Project Settings → API → service_role (배치 검수·RLS 우회)
# SUPABASE_SERVICE_ROLE_KEY=

# Vercel Cron 또는 수동 호출 시: Authorization: Bearer <값>
# CRON_SECRET=

# 공고 검수 OpenAI (선택 — 없으면 키워드만)
# OPENAI_API_KEY=
# OPENAI_MODERATION_MODEL=gpt-4o-mini
# 키워드만 걸린 경우에도 AI 호출(비용↑) — 기본 꺼짐
# MODERATION_AI_FOR_ALL=false

# /admin/moderation 시뮬 폼 허용 (로컬·스테이징만 true 권장)
# ADMIN_PLAYGROUND_ENABLED=false

# ========== 지도 대량 데모 (PRD §14.3) — 서버 전용, 프로덕션에서는 끄기 ==========
# true 이면 Faker로 가짜 공고 핀을 추가 생성(기본 MOCK 8건 + N건). 클라이언트 번들에 Faker 안 넣음.
# EXTRA_MOCK_JOBS=false
# EXTRA_MOCK_JOB_COUNT=200
# EXTRA_MOCK_JOBS_SEED=42
